# Khaao frontend — Firebase web app config (v3)
#
# All four values come from the SAME screen:
# console.firebase.google.com → your project → Project settings (gear icon) →
# General → "Your apps" → add/select a Web app (</>) → "SDK setup and
# configuration" → Config. These are public client identifiers, not secrets —
# access control happens on the backend (domain + allowlist checks).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
