# Khaao backend — environment variables (all optional; defaults shown)

# HTTP port the server listens on.
PORT=8080

# Database driver: sqlite | postgres
DB_DRIVER=sqlite

# For sqlite: path to the database file.
# For postgres: a standard DSN, e.g.
#   host=localhost user=khaao password=khaao dbname=khaao port=5432 sslmode=disable
DB_DSN=khaao.db

# Secret used to sign JWTs. Change this in any real deployment.
JWT_SECRET=dev-secret-change-me

# Comma-separated list of email domains allowed to sign up as students.
# Empty = allow any domain.
ALLOWED_EMAIL_DOMAINS=

# --- Auth methods -----------------------------------------------------------

# Google sign-in: OAuth 2.0 Web client ID from console.cloud.google.com
# (APIs & Services -> Credentials). Empty = Google button hidden.
GOOGLE_CLIENT_ID=

# Comma-separated Google account domains allowed to sign in, e.g.
# yourcollege.edu. Empty = falls back to ALLOWED_EMAIL_DOMAINS; both empty =
# any Google account.
GOOGLE_ALLOWED_DOMAINS=

# Allow "continue as guest" bookings (24h throwaway session, name only).
GUEST_ENABLED=true

# Classic email+password signup for students. Off by default now that
# Google + guest are the main paths (staff login always works).
PASSWORD_SIGNUP_ENABLED=false

# Minutes a "ready" order holds before it expires and returns its units
# to the done pool.
HOLD_MINUTES=15

# Origin allowed by CORS (the frontend dev server / deployed SPA).
FRONTEND_ORIGIN=http://localhost:5173

# Seeded shopkeeper account (no signup path for this role).
SHOPKEEPER_EMAIL=shopkeeper@canteen.local
SHOPKEEPER_PASSWORD=admin123
SHOPKEEPER_NAME=Canteen

# Seed ~6 sample Indian canteen menu items on boot if the menu table is empty.
SEED_SAMPLE_MENU=true
