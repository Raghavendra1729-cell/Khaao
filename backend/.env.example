# Khaao backend — environment variables (v3)

# HTTP port the server listens on.
PORT=8080

# dev | production. production refuses to boot with AUTH_FAKE=true.
APP_ENV=dev

# Postgres connection string (Postgres is the only supported DB in v3).
# Local dev example (Homebrew Postgres, no password):
#   postgres://lingaraghavendra@localhost:5432/khaao?sslmode=disable
DATABASE_URL=postgres://lingaraghavendra@localhost:5432/khaao?sslmode=disable

# Secret used to sign Khaao session JWTs. Change this in any real deployment.
JWT_SECRET=dev-secret-change-me

# --- Firebase auth (the ONLY login method) -----------------------------------

# Firebase console (console.firebase.google.com) → your project →
# Project settings (gear icon) → General → "Project ID".
# The backend verifies Google sign-in ID tokens against this project.
# No service-account key is needed for token verification.
FIREBASE_PROJECT_ID=

# Students must sign in with a Google account on this domain.
ALLOWED_EMAIL_DOMAIN=sst.scaler.com

# Comma-separated Google emails allowed to sign in as SHOPKEEPER (any domain —
# this is the allowlist exception). Seeded into the shopkeeper_emails table on
# boot; rows added there by hand also work.
# e.g. SHOPKEEPER_EMAILS=canteen.owner@gmail.com,manager@sst.scaler.com
SHOPKEEPER_EMAILS=

# DEV ONLY. true = accept fake tokens ("fake:<email>") so e2e tests can run
# without Google. NEVER enable in production.
AUTH_FAKE=false

# ------------------------------------------------------------------------------

# Minutes a fully-ready order holds before it expires and returns its units
# to the pool (orders with anything already handed over never expire).
HOLD_MINUTES=15

# IANA timezone for business-day/date logic (daily token reset, history dates).
# Keep this as the canteen's local zone regardless of where the server runs.
BUSINESS_TIMEZONE=Asia/Kolkata

# Origin allowed by CORS (the frontend dev server / deployed SPA).
FRONTEND_ORIGIN=http://localhost:5173

# Seed ~6 sample Indian canteen menu items on boot if the menu table is empty.
SEED_SAMPLE_MENU=true
